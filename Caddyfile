# Caddy 自動向 Let's Encrypt 申請憑證、自動續約。
#
# 路由分三類,都在同一個網域底下:
#   /webhook   -> FastAPI(接收 LINE 訊息)
#   /api/*     -> FastAPI(儀表板資料 API)
#   /dashboard -> 靜態 HTML 儀表板(零 build,Caddy 直接吐檔案)
#
# 順序重要:Caddy 會用最精確的 matcher,但這裡明確分開寫最清楚。

chargealert.zoesu.dev {
    # 後台儀表板(靜態檔案)
    handle_path /dashboard* {
        root * /srv/dashboard
        file_server
    }

    # LINE webhook + 儀表板 API 都轉給 FastAPI
    handle /webhook {
        reverse_proxy webhook:8000
    }
    handle /api/* {
        reverse_proxy webhook:8000
    }

    # 其餘(含首頁健康檢查 /)也交給 FastAPI
    handle {
        reverse_proxy webhook:8000
    }
}
